# WordPress 관련 파일 제외
wp-*.php
wp-*.html
gutenberg-*.html
*-gutenberg.html
wordpress/
wp-content/
wp-includes/
wp-admin/
*.php

# 임시/작업 파일
*_downloaded.*
*_backup.*
*_old.*
*_temp.*
_draft-*.html
draft-*.html

# 배포 스크립트 (Cloudflare Pages 자동배포로 대체)
deploy-*.js
deploy-*.sh

# 시스템 파일
.DS_Store
Thumbs.db
desktop.ini

# 에디터
.vscode/
.idea/

# 노드
node_modules/

# Cloudflare
.wrangler/

# Puppeteer/Edge temp profile (generated during PDF builds)
.edge-tmp/

